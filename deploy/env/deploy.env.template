# deploy/env/deploy.env.template
#
# SINGLE SOURCE OF TRUTH for the runtime env contract shared across the
# deployables (backend fly [env] AND the cron-manager's per-job config.env).
# It mirrors the PENNY_* / provider variables the app declares in
# backend/penny/config.py and backend/.env.example.
#
# This file is split into two halves:
#
#   1. NON-SECRET shared runtime values. These are safe to bake into a
#      committed fly.toml [env] block and into the cron config.env. The cron
#      env is GENERATED from this half by deploy/scripts/render_cron_env.sh,
#      so backend and cron can never disagree on model/provider.
#   2. SECRETS — names only, NO values. These never live in fly.toml or in a
#      committed schedules.json. Set them with `fly secrets set` on each app
#      (backend + cron-manager) instead.
#
# Editing the model/provider in one place updates every deployable.

# =============================================================================
# 1. NON-SECRET shared runtime values  (fly [env] + cron config.env)
# =============================================================================
PYTHONUNBUFFERED=1

# Agent / categorizer model selection. Penny runs on Gemini.
PENNY_AGENT_PROVIDER=gemini
PENNY_AGENT_MODEL=gemini-3.5-flash
PENNY_CATEGORIZER_MODEL=gemini-3.5-flash

# Workspace root inside the container. The cron job mounts a Fly volume here
# so memory/ and reports/ persist across runs; the backend uses the same path.
PENNY_WORKSPACE=/app/.transactoid

# Plaid environment (the secrets themselves are in section 2).
PLAID_ENV=production

# =============================================================================
# 2. SECRETS — names only. Set via `fly secrets set`, never committed.
# =============================================================================
# Required:
#   GOOGLE_API_KEY            Gemini API key for the agent + categorizer.
#   DATABASE_URL              Postgres (Neon prod) connection string.
#   PLAID_CLIENT_ID           Plaid app client id.
#   PLAID_PRODUCTION_SECRET   Plaid production secret (or PLAID_SANDBOX_SECRET).
#   R2_ACCOUNT_ID             Cloudflare R2 account id.
#   R2_ACCESS_KEY_ID          R2 access key id.
#   R2_SECRET_ACCESS_KEY      R2 secret access key.
#   R2_BUCKET                 R2 bucket name for report/artifact uploads.
#   RESEND_API_KEY            Resend API key for scheduled-report emails.
# Optional:
#   BROWSERBASE_API_KEY       Amazon scraper (Browserbase backend).
#   BROWSERBASE_PROJECT_ID    Amazon scraper project id.
#   PENNY_AGENT_THINKING_BUDGET  Gemini thinking budget (-1 dynamic; default).

# =============================================================================
# 3. FRONTEND build input  (deploy/frontend only)
# =============================================================================
# Origin the browser hits for the backend API. With the co-served/proxied
# single-origin model (the recommended shape) this is the same origin and the
# frontend proxies /api to the backend; for a separate frontend Fly app, set
# the backend's public origin here so the build can target it.
# BACKEND_ORIGIN=https://penny.fly.dev
