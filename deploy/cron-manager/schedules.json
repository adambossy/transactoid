[
    {
        "name": "penny-sync-12h",
        "app_name": "penny",
        "schedule": "0 0,12 * * *",
        "region": "iad",
        "command": "-lc '/app/.venv/bin/penny sync'",
        "command_timeout": 7200,
        "enabled": true,
        "config": {
            "metadata": {
                "fly_process_group": "cron"
            },
            "auto_destroy": true,
            "disable_machine_autostart": true,
            "init": {
                "entrypoint": [
                    "/bin/sh"
                ]
            },
            "guest": {
                "cpu_kind": "shared",
                "cpus": 1,
                "memory_mb": 1024
            },
            "mounts": [
                {
                    "name": "penny_workspace",
                    "path": "/app/.transactoid"
                }
            ],
            "restart": {
                "max_retries": 1,
                "policy": "no"
            }
        }
    },
