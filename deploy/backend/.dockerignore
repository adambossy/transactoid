# Build context = repo root. Trim everything the backend image does not need
# so the context stays small and no local SQLite / secret / node tree leaks in.

# VCS + worktrees
.git
**/.git
.worktrees

# Python caches / build artifacts
**/__pycache__
**/*.py[codz]
**/*.so
**/.venv
**/.uv
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache
**/build
**/dist
**/*.egg-info

# Local databases (gitignored backend/penny.db etc.)
**/*.db
**/*.sqlite3

# Secrets / local env
**/.env
**/.env.*
**/.certs
**/.logs
**/.transactions

# Frontend (not part of the backend image)
frontend

# Editor / agent dev config + planning scratch
.claude
.mcp.json
**/.DS_Store
plans
smartplan-*

# Tests are not needed at runtime
backend/tests
