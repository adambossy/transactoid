# Build context = repo root. Keep only what the frontend build needs.

.git
**/.git
.worktrees

# The backend tree is not part of the frontend image.
backend

# Node / build artifacts (rebuilt in-container; never copy host installs).
**/node_modules
**/dist
**/.vite
**/*.tsbuildinfo

# Secrets / local env
**/.env
**/.env.*
**/.certs
**/.logs

# Editor / agent dev config + planning scratch
.claude
.mcp.json
**/.DS_Store
plans
smartplan-*
