# Copy to .env and fill in. Loaded by penny.api.main via python-dotenv (override=False).
#
# To run against the Neon test branch instead of local SQLite, also source
# .env.test (written by the test-branch setup; gitignored).

# --- Model providers ---
# Penny's agent runs on Gemini (gemini-3.5-flash). The categorizer defaults
# to the same model via PENNY_CATEGORIZER_MODEL below.
GOOGLE_API_KEY=...
# Optional fallbacks — only needed if you switch agent_factory to another provider.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Categorizer ---
# Model used for transaction categorization (provider inferred from name).
PENNY_CATEGORIZER_MODEL=gemini-3.5-flash
# Optional: PENNY_AGENT_PROVIDER / PENNY_AGENT_MODEL / PENNY_AGENT_REASONING_EFFORT /
# PENNY_AGENT_VERBOSITY / PENNY_ENABLE_WEB_SEARCH (see penny/core/runtime/config.py).

# --- Database ---
# Defaults to sqlite:///./penny.db when unset. Set to a Postgres URL for real data.
# DATABASE_URL=sqlite:///./penny.db

# --- Workspace ---
# Root for the sandbox + memory/reports/budget files. Defaults to ~/.transactoid
# (kept from the prior product name so existing user state carries over).
# PENNY_WORKSPACE=~/.transactoid

# --- Plaid ---
PLAID_CLIENT_ID=...
PLAID_ENV=production            # sandbox | development | production
PLAID_SANDBOX_SECRET=...
PLAID_PRODUCTION_SECRET=...

# --- Cloudflare R2 (report/artifact uploads + investment-dedup archive) ---
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=...

# --- Email (send_email_report tool; Resend by default) ---
# RESEND_API_KEY=re_...

# --- Amazon scraping (optional; Browserbase-backed) ---
# BROWSERBASE_API_KEY=...
# BROWSERBASE_PROJECT_ID=...

# --- One-shot scripts ---
# Source DB for scripts/sync_taxonomy_from_supabase.py. Kept separate from
# DATABASE_URL so dev never accidentally talks to prod at runtime.
# SUPABASE_DATABASE_URL=postgresql://...
