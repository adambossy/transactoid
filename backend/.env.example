# Copy to .env and fill in. Loaded by penny.api.main via python-dotenv (override=False).

# --- Required ---
# Penny's primary model provider. The backend uses OpenAIResponsesModel
# (gpt-5.5 by default; see agent_harness.providers.openai).
OPENAI_API_KEY=sk-...

# --- Optional ---
# Local database URL. Defaults to a SQLite file at ./penny.db when unset.
# Set to a Postgres URL to point at a real DB.
# DATABASE_URL=sqlite:///./penny.db

# Workspace root for the in-process sandbox + skill memory.
# Defaults to ~/.transactoid (kept from the prior product name so existing
# state — budget.md, merchant-rules.md, reports/ — carries over).
# PENNY_WORKSPACE=~/.transactoid

# Only needed to bootstrap the local taxonomy seed: source URL for the
# `scripts/sync_taxonomy_from_supabase.py` one-shot. Keep separate from
# DATABASE_URL so dev never accidentally talks to prod at runtime.
# SUPABASE_DATABASE_URL=postgresql://...

# Optional: only needed if you switch agent_factory back to the Anthropic provider.
# ANTHROPIC_API_KEY=sk-ant-...
