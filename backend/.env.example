# Copy to .env and fill in. Loaded by penny.api.main via python-dotenv (override=False).
#
# To run against the Neon test branch instead of local SQLite, also source
# .env.test (written by the test-branch setup; gitignored).

# --- Model providers ---
# Penny's agent runs on Gemini (gemini-3.5-flash). The categorizer defaults
# to the same model via PENNY_CATEGORIZER_MODEL below.
GOOGLE_API_KEY=...
# Optional fallbacks — only needed if you switch agent_factory to another provider.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Categorizer ---
# Model used for transaction categorization (provider inferred from name).
PENNY_CATEGORIZER_MODEL=gemini-3.5-flash
# Optional: PENNY_AGENT_PROVIDER / PENNY_AGENT_MODEL / PENNY_AGENT_REASONING_EFFORT /
# PENNY_AGENT_VERBOSITY / PENNY_ENABLE_WEB_SEARCH (see penny/core/runtime/config.py).
# Thinking-token budget for the chat agent (Gemini semantics: -1 dynamic,
# 0 disables thinking and with it the streamed thought summaries in the UI).
# PENNY_AGENT_THINKING_BUDGET=-1

# --- Database ---
# Defaults to sqlite:///./penny.db when unset. Set to a Postgres URL for real data.
# DATABASE_URL=sqlite:///./penny.db

# --- Workspace ---
# Root for the sandbox + memory/reports/budget files. Defaults to ~/.transactoid
# (kept from the prior product name so existing user state carries over).
# PENNY_WORKSPACE=~/.transactoid

# --- Plaid ---
PLAID_CLIENT_ID=...
PLAID_ENV=production            # sandbox | development | production
PLAID_SANDBOX_SECRET=...
PLAID_PRODUCTION_SECRET=...
# Link flow (phase 5): `hosted` runs react-plaid-link in the browser with a
# server-side token exchange (POST /api/plaid/exchange); `localhost` keeps the
# dev connect_new_account browser flow. Default hosted.
PENNY_PLAID_LINK_MODE=hosted     # hosted | localhost
# OAuth redirect URI for hosted Link (must be allow-listed in the Plaid
# dashboard); include the app URL the card returns to. Optional in localhost.
PLAID_REDIRECT_URI=...

# --- Cloudflare R2 (report/artifact uploads + investment-dedup archive) ---
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=...

# --- Email (send_email_report tool; Resend by default) ---
# RESEND_API_KEY=re_...

# --- Amazon scraping (optional; Browserbase-backed) ---
# BROWSERBASE_API_KEY=...
# BROWSERBASE_PROJECT_ID=...

# --- Langfuse tracing (optional observability) ---
# Traces the agent loop (chat + cron) and the categorizer. Tracing turns on
# automatically when both keys are present; degrades to a no-op otherwise.
# Get keys from your Langfuse project settings (pk-lf-… / sk-lf-…).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://us.cloud.langfuse.com   # or https://cloud.langfuse.com (EU); omit for default
# Explicit on/off override (defaults to: on iff both keys are set):
# PENNY_LANGFUSE_ENABLED=true
# Optional environment tag shown in the Langfuse UI:
# PENNY_LANGFUSE_ENVIRONMENT=development

# --- Sentry error tracking (optional) ---
# Ships unhandled exceptions from the API + CLI/cron to Sentry. On by default
# using the project DSN baked into penny/observability/sentry.py (a Sentry DSN
# is a public client key). Override or disable here:
# PENNY_SENTRY_DSN=            # set empty to disable; unset uses the default DSN
# PENNY_SENTRY_ENABLED=true    # explicit on/off (defaults to: on iff a DSN resolves)
# PENNY_SENTRY_ENVIRONMENT=production

# --- Security ---
# Fernet key encrypting plaid_items.access_token at rest (v1-stamped; see
# penny/security/token_cipher.py). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Unset in dev (PENNY_AUTH_MODE=dev) => tokens stored plaintext (dev
# convenience); migration 017 encrypts the backlog once the key is configured.
# REQUIRED in clerk (prod) mode: storing a token with no key set fails closed
# (raises) rather than persisting it in cleartext (F07). The same key also
# encrypts BYO provider credentials (phase 2b credential vault).
# PENNY_PLAID_TOKEN_KEY=...
# Key rotation (non-destructive): add the new version's key here, bump
# _ACTIVE_VERSION in token_cipher.py, and KEEP the prior key(s) set so existing
# v1: ciphertext still decrypts. Prior/other versions read from
# PENNY_PLAID_TOKEN_KEY_V<N> (v1 also reads PENNY_PLAID_TOKEN_KEY above).
# PENNY_PLAID_TOKEN_KEY_V2=...

# --- Billing: BYO keys & metered subsidy (phase 2b) ---
# Metered billing is OFF unless PENNY_SUBSIDY_PROVIDER_KEY is set (dev/self-host
# then runs chat on GOOGLE_API_KEY with no metering). When set on a shared
# server, each user gets a subsidized runway; once spent they must connect their
# own provider key (Settings → Providers & billing) or a sanctioned OAuth sub.
#
# Platform provider key a subsidized run bills against (the active Gemini/google
# runtime):
# PENNY_SUBSIDY_PROVIDER_KEY=...
# Per-user grant on first Plaid link, in cents (default 200 = $2/user; a
# two-spouse household that both connect gets $4):
# PENNY_SUBSIDY_CENTS=200
# Model price table (JSON, $/million tokens) used to price completions against
# the subsidy. Missing models price at zero.
# PENNY_MODEL_PRICES={"gemini-3.5-flash":{"input":0.30,"output":2.50,"cache_read":0.075}}
#
# Sanctioned subscription OAuth — only for providers where we register our own
# client (Claude Pro/Max is excluded). Per provider (UPPERCASED):
# PENNY_OAUTH_<PROVIDER>_CLIENT_ID=...
# PENNY_OAUTH_<PROVIDER>_CLIENT_SECRET=...
# PENNY_OAUTH_<PROVIDER>_AUTHORIZE_URL=https://provider/authorize
# PENNY_OAUTH_<PROVIDER>_TOKEN_URL=https://provider/token
# PENNY_OAUTH_<PROVIDER>_REDIRECT_URI=https://your-domain/api/providers/<provider>/oauth/callback
# PENNY_OAUTH_<PROVIDER>_SCOPES="..."

# --- Auth (phase 2: Clerk social login) ---
# Auth mode. Defaults to "clerk" (fail closed). In "clerk" mode the backend
# verifies a Clerk-issued RS256 JWT per request and IGNORES the dev X-Penny-*
# headers; the three clerk vars below are then REQUIRED (startup raises if any
# is missing). Set to "dev" for local work with the env-pinned PENNY_DEV_*
# principal (no header spoofing) — never in prod.
# PENNY_AUTH_MODE=clerk
# Expected token issuer (verified against the JWT's iss). From your Clerk app.
# PENNY_CLERK_ISSUER=https://<your-subdomain>.clerk.accounts.dev
# JWKS URL — the public signing keys. Comes from CONFIG, never the token's iss.
# PENNY_CLERK_JWKS_URL=https://<your-subdomain>.clerk.accounts.dev/.well-known/jwks.json
# Optional expected audience; when set, the JWT's aud is verified against it.
# PENNY_CLERK_AUDIENCE=
# The frontend origin allowed by CORS (required in clerk mode; localhost:5173 is
# always allowed for dev). Never combined with a wildcard.
# PENNY_FRONTEND_ORIGIN=https://penny.example.com
# Clerk secret key — backend server key (used by phase-4 invites; documented now).
# CLERK_SECRET_KEY=sk_...

# --- run_sql read-only role (phase 2 hardening) ---
# The agent's free-form run_sql runs on a dedicated read-only Postgres role so a
# prompt-injected write is rejected by the DB itself (RLS still scopes reads).
# REQUIRED in clerk mode; in dev it falls back to DATABASE_URL (SQLite has no
# roles). One-time role setup on Neon/Postgres (replace <owner> with the role
# that owns the tables / runs migrations, e.g. the DATABASE_URL role):
#   CREATE ROLE penny_agent_ro LOGIN PASSWORD '...';
#   GRANT USAGE ON SCHEMA public TO penny_agent_ro;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO penny_agent_ro;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO penny_agent_ro;
#   -- Read-only means no new tables either: without this, schema-level CREATE
#   -- (PUBLIC's default on older PG / some hosts) lets the role create tables.
#   REVOKE CREATE ON SCHEMA public FROM PUBLIC;
#   REVOKE CREATE ON SCHEMA public FROM penny_agent_ro;
#   -- F02/F05: deny the agent the ability to flip the tenant GUC mid-query.
#   -- set_config's EXECUTE is granted to PUBLIC, so revoke from PUBLIC and
#   -- re-grant only to <owner>; the agent pins its context via penny_set_tenant
#   -- (installed by migration 024) instead.
#   -- NOTE: on Neon these two are silent no-ops ("no privileges could be
#   -- revoked") — <owner> can't alter pg_catalog ACLs there. The operative
#   -- layer on Neon is the input parse guard, which denylists set_config
#   -- (security/sql_read_guard.py).
#   REVOKE EXECUTE ON FUNCTION pg_catalog.set_config(text, text, boolean) FROM PUBLIC;
#   GRANT EXECUTE ON FUNCTION pg_catalog.set_config(text, text, boolean) TO "<owner>";
#   GRANT EXECUTE ON FUNCTION penny_set_tenant(text, text) TO penny_agent_ro;
#   -- F04: users/households carry no RLS — keep them out of run_sql's reach so
#   -- it cannot enumerate every email/Clerk-id and household UUID.
#   REVOKE SELECT ON users, households FROM penny_agent_ro;
#   -- F21/F32: confine the role to the finance schema so it can never reach the
#   -- website's web.* app schema, even by accident.
#   ALTER ROLE penny_agent_ro SET search_path = public;
#   REVOKE ALL ON SCHEMA web FROM penny_agent_ro;  -- if the web app schema exists
# PENNY_AGENT_READONLY_DATABASE_URL=postgresql://penny_agent_ro:...@host/db
# The categorizer eval reuses this SELECT-only role for its bulk finance reads
# (it snapshots prod into a local SQLite copy — no Neon branch/API key/neonctl).
# For the Postgres-marked read-only test (tests/tools/test_run_sql_readonly.py):
# POSTGRES_TEST_RO_URL=postgresql://penny_agent_ro:...@host/db
# POSTGRES_TEST_RO_ROLE=penny_agent_ro

# --- Cron principal (phase 2: scheduled reports run with an explicit context) ---
# Cron builds a RequestContext per job and refuses to run without these (never
# runs RLS-unscoped). One individual report per user id, plus one household
# (joint) report. send_email_report derives recipients from this context.
# PENNY_CRON_HOUSEHOLD_ID=22222222-2222-2222-2222-222222222222
# PENNY_CRON_USER_IDS=11111111-1111-1111-1111-111111111111,33333333-3333-3333-3333-333333333333

# --- Tenancy (dev-stub principal; used only in PENNY_AUTH_MODE=dev) ---
# Every request/CLI run is scoped to a user + household. In dev mode the
# principal comes from X-Penny-* request headers or these env fallbacks. Required
# for headless runs (penny CLI / cron) and for /api/chat in dev mode.
# PENNY_DEV_USER_ID=11111111-1111-1111-1111-111111111111
# PENNY_DEV_HOUSEHOLD_ID=22222222-2222-2222-2222-222222222222
# PENNY_DEV_SESSION_MODE=individual   # or: joint
# Opt-in for migration 013's dev backfill (creates the dev household + two
# users and assigns pre-tenancy rows). Never set on prod — the phase-3
# cutover owns prod ownership assignment.
# PENNY_DEV_BACKFILL=1
# PENNY_DEV_USER_EMAIL=you@example.com
# PENNY_DEV_USER2_ID=33333333-3333-3333-3333-333333333333
# PENNY_DEV_USER2_EMAIL=partner@example.com
# Postgres-marked test suites (RLS isolation) run only when this is set —
# point it at the Neon penny-test branch or a local NON-superuser role
# (superusers bypass RLS): see tests/conftest_postgres.py.
# POSTGRES_TEST_URL=postgresql://...

# --- One-shot scripts ---
# Source DB for scripts/sync_taxonomy_from_supabase.py. Kept separate from
# DATABASE_URL so dev never accidentally talks to prod at runtime.
# SUPABASE_DATABASE_URL=postgresql://...
